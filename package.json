{
  "name": "@bughq/monorepo",
  "type": "module",
  "version": "0.1.3",
  "private": true,
  "description": "bughq error-tracking SDKs — core, Vue, Nuxt, and Stacks/stx",
  "author": "bughq",
  "license": "MIT",
  "homepage": "https://bughq.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/bughq/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/bughq/sdk/issues"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "test": "bun run scripts/build.ts && bun test",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "format": "bunx --bun pickier . --format",
    "format:fix": "bunx --bun pickier . --format --write",
    "typecheck": "bunx --bun tsc --noEmit",
    "publish:packages": "bun run scripts/build.ts && bun run scripts/publish.ts",
    "release": "bumpp package.json 'packages/*/package.json'",
    "release:patch": "bumpp patch --yes package.json 'packages/*/package.json'",
    "release:minor": "bumpp minor --yes package.json 'packages/*/package.json'",
    "release:major": "bumpp major --yes package.json 'packages/*/package.json'"
  },
  "devDependencies": {
    "@nuxt/kit": "^3.14.0",
    "bumpp": "^12.0.0",
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.2",
    "pickier": "^0.1.38",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vue": "^3.5.13"
  }
}
